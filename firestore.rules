rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is the administrator
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'rohan.dey1206@gmail.com';
    }

    // Helper function to check if the user owns the registration document
    function isOwner(resourceData) {
      return request.auth != null && (
        resourceData.email == request.auth.token.email || 
        (hasField(resourceData, 'userId') && resourceData.userId == request.auth.uid)
      );
    }

    // Helper function to check if document has a specific field
    function hasField(data, field) {
      return field in data;
    }

    // Rules for the registrations collection
    match /registrations/{registrationId} {
      
      // Anyone who is authenticated can read registrations to allow student lookups and card renderings
      allow read: if request.auth != null;
      
      // Create is allowed if the user is an admin, OR they are registering themselves (matching their authenticated email or userId)
      allow create: if isAdmin() || (
        request.auth != null && (
          request.resource.data.email == request.auth.token.email ||
          request.resource.data.userId == request.auth.uid
        )
      );

      // Update is allowed if the user is an admin, OR they own the registration
      allow update: if isAdmin() || isOwner(resource.data);

      // Only administrators can delete registrations
      allow delete: if isAdmin();
    }
  }
}
